{
  "_comment": "Flat test catalog with boundary-discipline schema (v8.18.28). 8 features, no groups. Each leaf carries description + positive_examples + negative_examples (boundary cases) + exclusions. Exclusions flow into the annotator suffix (', NOT X, NOT Y') so the labeler can disambiguate. The schema mirrors what inventory.organize_hierarchy now demands of every Sonnet-generated leaf.",
  "features": [
    {
      "id": "comma",
      "description": "Token is a comma",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        "red>>,<< blue, and green",
        "She said>>,<< 'wait'",
        "John>>,<< Mary>>,<< and Sue",
        "First>>,<< then second"
      ],
      "negative_examples": [
        "10>>.<<5 percent",
        "etc>>.<<",
        "John>>'<<s book",
        "Hello>>;<< goodbye"
      ],
      "exclusions": [
        "semicolons",
        "apostrophes",
        "periods"
      ]
    },
    {
      "id": "period",
      "description": "Token is a sentence-final period (the period that ends a complete sentence)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        "The cat sat>>.<< Then it left",
        "She arrived>>.<< She left",
        "I agree>>.<< Wait, on second thought"
      ],
      "negative_examples": [
        "Dr>>.<< Smith arrived",
        "3>>.<<14 is approximate",
        "U>>.<<S>>.<<A>>.<< is the country",
        "etc>>.<<",
        "i>>.<<e>>.<<"
      ],
      "exclusions": [
        "abbreviation periods",
        "decimal points",
        "initialism periods"
      ]
    },
    {
      "id": "preposition",
      "description": "Token is a preposition introducing a prepositional phrase (in, on, at, of, for, with, to, from, by)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        "sat >>on<< the chair",
        "letter >>from<< Paris",
        "fight >>for<< freedom",
        "made >>by<< hand"
      ],
      "negative_examples": [
        "want >>to<< leave",
        "I went >>to<< sleep",
        "going >>to<< school as a goal",
        "She tried >>to<< help"
      ],
      "exclusions": [
        "infinitive marker 'to'",
        "particle 'to' in phrasal verbs"
      ]
    },
    {
      "id": "pronoun",
      "description": "Token is a personal pronoun functioning as subject or object (he, she, it, they, we, I, you, him, her, them, us, me)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        ">>She<< arrived early",
        "I told >>him<< the truth",
        ">>They<< left quickly",
        "between you and >>me<<"
      ],
      "negative_examples": [
        ">>His<< book is here",
        ">>My<< friend left",
        ">>Their<< house burned",
        ">>Itself<< was unusual"
      ],
      "exclusions": [
        "possessive determiners (his, her, my, your, their)",
        "reflexive pronouns (himself, herself)"
      ]
    },
    {
      "id": "determiner",
      "description": "Token is a definite/indefinite article or demonstrative determiner immediately preceding a noun (the, a, an, this, that, these, those)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        ">>The<< cat sat",
        ">>An<< apple a day",
        ">>This<< book is mine",
        ">>Those<< trees are tall"
      ],
      "negative_examples": [
        ">>That<< he came was surprising",
        ">>This<< is mine (predicative pronoun)",
        ">>The<< more, the merrier (correlative)",
        ">>A<< (the letter A as a token)"
      ],
      "exclusions": [
        "demonstrative pronouns",
        "complementizer 'that'",
        "letter-name 'a'"
      ]
    },
    {
      "id": "capitalized",
      "description": "Token's first alphabetic character is uppercase and at least one subsequent character is lowercase (mixed-case word, not an all-caps acronym)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        ">>John<< went home",
        ">>Paris<< is a city",
        ">>Monday<< morning",
        ">>The<< cat (sentence-initial)"
      ],
      "negative_examples": [
        ">>NASA<< launched (all caps)",
        ">>USA<< is large",
        ">>iPhone<< (lowercase first)",
        ">>123<< Main Street (digit)"
      ],
      "exclusions": [
        "all-caps acronyms",
        "tokens starting with non-letter",
        "lowercase-first compound names"
      ]
    },
    {
      "id": "digit",
      "description": "Token consists entirely of digits 0-9 (a pure number, not a word containing digits)",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        "year >>2024<<",
        "page >>3<<",
        "section >>12<<",
        "1>>2<<3 sequence"
      ],
      "negative_examples": [
        ">>1st<< place (ordinal)",
        ">>3D<< printer (alphanumeric)",
        ">>USB-C<< (mixed)",
        ">>15th<< floor"
      ],
      "exclusions": [
        "ordinals (1st, 2nd, 3rd)",
        "alphanumeric mixed tokens",
        "tokens containing letters"
      ]
    },
    {
      "id": "short",
      "description": "Token is exactly 1 or 2 characters long, counting any leading space as part of BPE tokenization but not toward length",
      "type": "leaf",
      "parent": null,
      "positive_examples": [
        ">>I<< went",
        ">> a<< cat",
        ">>is<< ready",
        ">>of<< it"
      ],
      "negative_examples": [
        ">>the<< (3 chars)",
        ">>and<< (3 chars)",
        ">> cat<< (3 letters)",
        ">>123<< (3 digits)"
      ],
      "exclusions": [
        "tokens with 3+ alphanumeric characters",
        "punctuation tokens (count separately)"
      ]
    }
  ]
}
